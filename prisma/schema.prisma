generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum FamilyRole {
  FATHER
  MOTHER
  SON
  DAUGHTER
  BROTHER
  SISTER
  GRANDFATHER
  GRANDMOTHER
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum RSVPStatus {
  GOING
  NOT_GOING
  MAYBE
}

// ─── Core Models ───────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  firstName     String
  lastName      String?
  email         String      @unique
  passwordHash  String
  dateOfBirth   DateTime?
  profileImage  String?
  familyRole    FamilyRole?
  gender        Gender?
  onboardingDone Boolean    @default(false)

  familyId      String?
  family        Family?     @relation(fields: [familyId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  moments         Moment[]
  birthdayWishes  BirthdayWish[]
  mealRSVPs       MealRSVP[]
  mealEvents      MealEvent[]
  experiences     ExperiencePost[]
  messages        FamilyMessage[]
  invitesCreated  FamilyInvite[]   @relation("InviteCreator")

  // NextAuth
  accounts        Account[]
  sessions        Session[]

  @@index([familyId])
  @@index([email])
}

model Family {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  emoji       String?  @default("🏠")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]
  invites     FamilyInvite[]
  moments     Moment[]
  meals       MealEvent[]
  experiences ExperiencePost[]
  messages    FamilyMessage[]
  wishes      BirthdayWish[]
}

model FamilyInvite {
  id          String    @id @default(cuid())
  code        String    @unique
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  expiresAt   DateTime?
  maxUses     Int       @default(10)
  useCount    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([familyId])
}

// ─── Moments ───────────────────────────────────────────────────────────────────

model Moment {
  id        String   @id @default(cuid())
  caption   String?
  imageUrl  String?
  publicId  String?  // Cloudinary public ID for deletion
  emoji     String?

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, createdAt(sort: Desc)])
  @@index([authorId])
}

// ─── Birthdays ─────────────────────────────────────────────────────────────────

model BirthdayWish {
  id         String   @id @default(cuid())
  message    String
  year       Int
  fromUserId String
  fromUser   User     @relation(fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String   // the birthday person's User ID
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId, year]) // one wish per person per year
  @@index([toUserId, year])
  @@index([familyId])
}

// ─── Meals ─────────────────────────────────────────────────────────────────────

model MealEvent {
  id          String     @id @default(cuid())
  title       String
  notes       String?
  location    String?
  scheduledAt DateTime
  imageUrl    String?

  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  familyId    String
  family      Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  rsvps       MealRSVP[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([familyId, scheduledAt])
}

model MealRSVP {
  id          String     @id @default(cuid())
  status      RSVPStatus
  note        String?

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealEventId String
  mealEvent   MealEvent  @relation(fields: [mealEventId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, mealEventId])
  @@index([mealEventId])
}

// ─── Experiences ───────────────────────────────────────────────────────────────

model ExperiencePost {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  publicId  String?
  title     String?

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, createdAt(sort: Desc)])
}

// ─── Messages ──────────────────────────────────────────────────────────────────

model FamilyMessage {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  emoji     String?

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([familyId, createdAt(sort: Desc)])
}

// ─── NextAuth Models ───────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
